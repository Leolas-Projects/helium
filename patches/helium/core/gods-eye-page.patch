+    @media (prefers-color-scheme: dark) {
+      :root {
+        --bg: #1a1a1a;
+        --surface: #242424;
+        --text: #f0f0f0;
+        --text-muted: #aaa;
+        --border: #333;
+        --helium-blue-light: #1e2a5c;
+      }
+    }
+    * { box-sizing: border-box; margin: 0; padding: 0; }
+    body {
