+      border-radius: var(--radius); font-size: 14px;
+      background: var(--bg); color: var(--text); outline: none;
+    }
+    input:focus { border-color: var(--helium-blue); }
+    input:disabled { opacity: 0.5; cursor: not-allowed; }
+    .time-note { font-size: 12px; color: var(--text-muted); margin-top: 6px; }
+    .row { display: flex; gap: 8px; margin-top: 10px; }
+    .row input { flex: 1; }
+    button {
+      padding: 9px 18px; border-radius: var(--radius); border: none;
+      font-size: 14px; cursor: pointer; font-weight: 500;
+    }
+    button:disabled { opacity: 0.45; cursor: not-allowed; }
+    .btn-add { background: var(--helium-blue-light); color: var(--helium-blue); }
+    .btn-remove {
+      background: none; border: none; color: #c0392b;
+      cursor: pointer; font-size: 18px; padding: 0 6px; line-height: 1;
+    }
+    .btn-remove:disabled { opacity: 0.3; cursor: not-allowed; }
+    .btn-save {
+      width: 100%; padding: 12px; font-size: 15px;
+      background: var(--helium-blue); color: white;
+      border-radius: var(--radius); border: none;
+      cursor: pointer; font-weight: 600; margin-top: 8px;
