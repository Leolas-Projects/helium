+<!DOCTYPE html>
+<html lang="en">
+<head>
+  <meta charset="UTF-8">
+  <meta name="viewport" content="width=device-width, initial-scale=1.0">
+  <title>God's Eye</title>
+  <style>
+    :root {
+      --helium-blue: #3450d1;
+      --helium-blue-light: #e8ecfb;
+      --bg: #f5f5f5;
+      --surface: #ffffff;
+      --text: #1a1a1a;
+      --text-muted: #666;
+      --border: #e0e0e0;
+      --radius: 8px;
+    }
+    @media (prefers-color-scheme: dark) {
+      :root {
+        --bg: #1a1a1a;
+        --surface: #242424;
+        --text: #f0f0f0;
+        --text-muted: #aaa;
+        --border: #333;
+        --helium-blue-light: #1e2a5c;
+      }
+    }
+    * { box-sizing: border-box; margin: 0; padding: 0; }
+    body {
+      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
+      background: var(--bg); color: var(--text); min-height: 100vh;
+    }
+    .header {
+      background: var(--helium-blue); color: white;
+      padding: 24px 32px 20px; display: flex; align-items: center; gap: 14px;
+    }
+    .header-icon { font-size: 28px; }
+    .header h1 { font-size: 22px; font-weight: 600; }
+    .header p { font-size: 13px; opacity: 0.85; margin-top: 2px; }
+    .container { max-width: 760px; margin: 0 auto; padding: 28px 24px; }
+    .card {
+      background: var(--surface); border: 1px solid var(--border);
+      border-radius: var(--radius); padding: 20px; margin-bottom: 20px;
+    }
+    .card-title {
+      font-size: 15px; font-weight: 600; margin-bottom: 14px;
+      display: flex; align-items: center; gap: 8px;
+    }
+    .status-bar {
+      display: flex; align-items: center; gap: 10px; padding: 10px 14px;
+      border-radius: var(--radius); font-size: 13px; margin-bottom: 20px;
+    }
+    .status-bar.active {
+      background: var(--helium-blue-light); color: var(--helium-blue);
+      border: 1px solid var(--helium-blue);
+    }
+    .status-bar.inactive {
+      background: var(--surface); color: var(--text-muted);
+      border: 1px solid var(--border);
+    }
+    label { display: block; font-size: 13px; color: var(--text-muted); margin-bottom: 6px; }
+    input[type="datetime-local"], input[type="text"] {
+      width: 100%; padding: 9px 12px; border: 1px solid var(--border);
+      border-radius: var(--radius); font-size: 14px;
+      background: var(--bg); color: var(--text); outline: none;
+    }
+    input:focus { border-color: var(--helium-blue); }
+    input:disabled { opacity: 0.5; cursor: not-allowed; }
+    .time-note { font-size: 12px; color: var(--text-muted); margin-top: 6px; }
+    .row { display: flex; gap: 8px; margin-top: 10px; }
+    .row input { flex: 1; }
+    button {
+      padding: 9px 18px; border-radius: var(--radius); border: none;
+      font-size: 14px; cursor: pointer; font-weight: 500;
