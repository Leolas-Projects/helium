+    }
+    .tag.locked { background: var(--bg); color: var(--text-muted); border: 1px solid var(--border); }
+    .empty-hint { font-size: 13px; color: var(--text-muted); font-style: italic; }
+    .expiry-display { font-size: 13px; color: var(--text-muted); margin-top: 6px; }
+    #save-error { color: #c0392b; font-size: 13px; margin-top: 8px; display: none; }
+    #debug-panel { margin-top: 30px; border-top: 1px solid var(--border); padding-top: 15px; }
+    #debug-toggle {
+      background: none; border: 1px solid var(--border); padding: 6px 12px;
+      font-size: 12px; color: var(--text-muted); border-radius: 4px; cursor: pointer;
+    }
+    #debug-log {
+      display: none; margin-top: 10px; padding: 12px;
+      background: var(--bg); border: 1px solid var(--border); border-radius: 8px;
+      font-size: 11px; font-family: Menlo, Monaco, monospace; color: var(--text);
+      max-height: 300px; overflow: auto; white-space: pre-wrap; word-break: break-all;
+    }
