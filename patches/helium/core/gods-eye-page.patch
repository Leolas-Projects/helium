+namespace {
+
+// Convenience accessor. Local State holds the single Gods Eye config shared
+// across all profiles, incognito, and guest sessions.
+PrefService* LocalState() {
+  return g_browser_process ? g_browser_process->local_state() : nullptr;
+}
+
+// Normalizes a domain string for user-allowlist comparison: lowercased,
+// leading scheme/path stripped, leading "www." stripped, trailing slash
+// stripped. Returns the empty string for unusable input.
+std::string NormalizeDomainInput(std::string_view raw) {
+  std::string s(raw);
+  s = base::ToLowerASCII(s);
+  // Strip optional scheme.
+  for (std::string_view scheme : {"https://", "http://"}) {
+    if (base::StartsWith(s, scheme, base::CompareCase::SENSITIVE)) {
+      s = s.substr(scheme.size());
+      break;
+    }
+  }
+  // Strip path component if any.
+  size_t slash = s.find('/');
+  if (slash != std::string::npos) {
+    s = s.substr(0, slash);
+  }
+  // Strip leading "www."
+  if (base::StartsWith(s, "www.", base::CompareCase::SENSITIVE)) {
+    s = s.substr(4);
+  }
+  // Trim whitespace.
+  base::TrimString(s, " \t\n\r", &s);
+  return s;
+}
+
+bool DomainInList(const base::Value::List& list, std::string_view domain) {
+  for (const base::Value& entry : list) {
+    const base::Value::Dict* d = entry.GetIfDict();
+    if (!d) {
+      continue;
+    }
+    const std::string* val = d->FindString("domain");
+    if (val && *val == domain) {
+      return true;
+    }
+  }
+  return false;
+}
+
+bool DomainInHardcoded(std::string_view domain) {
+  // kGodsEyeAllowedHosts is normalized (no "www." prefix, lowercase).
+  for (const char* allowed : kGodsEyeAllowedHosts) {
+    if (domain == allowed) {
+      return true;
+    }
+  }
+  return false;
+}
+
+}  // namespace
+
+GodsEyeHandler::GodsEyeHandler(content::BrowserContext* browser_context)
+    : browser_context_(browser_context) {}
+
+GodsEyeHandler::~GodsEyeHandler() = default;
+
+void GodsEyeHandler::RegisterMessages() {
+  web_ui()->RegisterMessageCallback(
+      "getGodsEyeData",
+      base::BindRepeating(&GodsEyeHandler::HandleGetGodsEyeData,
+                          base::Unretained(this)));
+  web_ui()->RegisterMessageCallback(
+      "saveGodsEyeData",
+      base::BindRepeating(&GodsEyeHandler::HandleSaveGodsEyeData,
+                          base::Unretained(this)));
+  web_ui()->RegisterMessageCallback(
+      "addDomain",
+      base::BindRepeating(&GodsEyeHandler::HandleAddDomain,
+                          base::Unretained(this)));
+  web_ui()->RegisterMessageCallback(
+      "addKeyword",
+      base::BindRepeating(&GodsEyeHandler::HandleAddKeyword,
+                          base::Unretained(this)));
+  web_ui()->RegisterMessageCallback(
+      "removeDomain",
+      base::BindRepeating(&GodsEyeHandler::HandleRemoveDomain,
+                          base::Unretained(this)));
+  web_ui()->RegisterMessageCallback(
+      "removeKeyword",
+      base::BindRepeating(&GodsEyeHandler::HandleRemoveKeyword,
+                          base::Unretained(this)));
+  web_ui()->RegisterMessageCallback(
+      "addAllowlistDomain",
+      base::BindRepeating(&GodsEyeHandler::HandleAddAllowlistDomain,
+                          base::Unretained(this)));
+  web_ui()->RegisterMessageCallback(
+      "removeAllowlistDomain",
+      base::BindRepeating(&GodsEyeHandler::HandleRemoveAllowlistDomain,
+                          base::Unretained(this)));
+  web_ui()->RegisterMessageCallback(
+      "cancelAllowlistPending",
+      base::BindRepeating(&GodsEyeHandler::HandleCancelAllowlistPending,
+                          base::Unretained(this)));
+}
+
+void GodsEyeHandler::HandleGetGodsEyeData(const base::ListValue& args) {
+  AllowJavascript();
+  const std::string& callback_id = args[0].GetString();
+
+  PrefService* prefs = LocalState();
+  if (!prefs) {
+    ResolveJavascriptCallback(base::Value(callback_id), base::Value());
+    return;
+  }
+
+  // Promote any pending allowlist entries whose 72h review window has elapsed.
+  GodsEyePromoteExpiredPendingAllowlist(prefs);
+
+  const base::Value::List& domains =
+      prefs->GetList(prefs::kGodsEyeBlockedDomains);
+  const base::Value::List& keywords =
+      prefs->GetList(prefs::kGodsEyeBlockedKeywords);
+  const base::Value::List& user_allowed =
+      prefs->GetList(prefs::kGodsEyeUserAllowedDomains);
+  const base::Value::List& pending =
+      prefs->GetList(prefs::kGodsEyeAllowlistPending);
+  double expiry = prefs->GetDouble(prefs::kGodsEyeExpiryTimestamp);
+  bool active = prefs->GetBoolean(prefs::kGodsEyeActive);
+
+  if (active && expiry > 0.0) {
+    double now = base::Time::Now().InSecondsFSinceUnixEpoch();
+    if (now >= expiry) {
+      prefs->SetBoolean(prefs::kGodsEyeActive, false);
+      active = false;
+    }
+  }
+
+  base::DictValue result;
+  result.Set("domains", domains.Clone());
+  result.Set("keywords", keywords.Clone());
+  result.Set("expiryTimestamp", expiry);
+  result.Set("active", active);
+  result.Set("userAllowedDomains", user_allowed.Clone());
+  result.Set("allowlistPending", pending.Clone());
+  result.Set("allowlistReviewSeconds", kGodsEyeAllowlistReviewSeconds);
+
+  ResolveJavascriptCallback(base::Value(callback_id),
+                             base::Value(std::move(result)));
+}
+
+void GodsEyeHandler::HandleSaveGodsEyeData(const base::ListValue& args) {
+  AllowJavascript();
+  const std::string& callback_id = args[0].GetString();
+
+  if (args.size() < 4) {
+    ResolveJavascriptCallback(base::Value(callback_id), base::Value(false));
+    return;
+  }
+
+  PrefService* prefs = LocalState();
+  if (!prefs) {
+    ResolveJavascriptCallback(base::Value(callback_id), base::Value(false));
+    return;
+  }
+
+  const base::ListValue* domains = args[1].GetIfList();
+  const base::ListValue* keywords = args[2].GetIfList();
+  double expiry = args[3].GetDouble();
+
+  if (!domains || !keywords || expiry <= 0.0) {
+    ResolveJavascriptCallback(base::Value(callback_id), base::Value(false));
+    return;
+  }
+
+  prefs->SetList(prefs::kGodsEyeBlockedDomains, domains->Clone());
+  prefs->SetList(prefs::kGodsEyeBlockedKeywords, keywords->Clone());
+  prefs->SetDouble(prefs::kGodsEyeExpiryTimestamp, expiry);
+  prefs->SetBoolean(prefs::kGodsEyeActive, true);
+
+  ResolveJavascriptCallback(base::Value(callback_id), base::Value(true));
+}
+
+void GodsEyeHandler::HandleAddDomain(const base::ListValue& args) {
+  AllowJavascript();
+  const std::string& callback_id = args[0].GetString();
+  PrefService* prefs = LocalState();
+  if (!prefs || args.size() < 2 || !args[1].is_string()) {
+    ResolveJavascriptCallback(base::Value(callback_id), base::Value(false));
+    return;
+  }
+  const std::string& domain = args[1].GetString();
+  if (domain.empty()) {
+    ResolveJavascriptCallback(base::Value(callback_id), base::Value(false));
+    return;
+  }
+  ScopedListPrefUpdate update(prefs, prefs::kGodsEyeBlockedDomains);
+  for (const auto& entry : *update) {
+    if (entry.is_string() && entry.GetString() == domain) {
+      ResolveJavascriptCallback(base::Value(callback_id), base::Value(true));
+      return;
+    }
+  }
+  update->Append(domain);
+  ResolveJavascriptCallback(base::Value(callback_id), base::Value(true));
+}
+
+void GodsEyeHandler::HandleAddKeyword(const base::ListValue& args) {
+  AllowJavascript();
+  const std::string& callback_id = args[0].GetString();
+  PrefService* prefs = LocalState();
+  if (!prefs || args.size() < 2 || !args[1].is_string()) {
+    ResolveJavascriptCallback(base::Value(callback_id), base::Value(false));
+    return;
+  }
+  const std::string& keyword = args[1].GetString();
+  if (keyword.empty()) {
+    ResolveJavascriptCallback(base::Value(callback_id), base::Value(false));
+    return;
+  }
+  ScopedListPrefUpdate update(prefs, prefs::kGodsEyeBlockedKeywords);
+  for (const auto& entry : *update) {
+    if (entry.is_string() && entry.GetString() == keyword) {
+      ResolveJavascriptCallback(base::Value(callback_id), base::Value(true));
+      return;
+    }
+  }
+  update->Append(keyword);
+  ResolveJavascriptCallback(base::Value(callback_id), base::Value(true));
+}
+
+void GodsEyeHandler::HandleRemoveDomain(const base::ListValue& args) {
+  AllowJavascript();
+  const std::string& callback_id = args[0].GetString();
+  PrefService* prefs = LocalState();
+  if (!prefs || args.size() < 2 || !args[1].is_string()) {
+    ResolveJavascriptCallback(base::Value(callback_id), base::Value(false));
+    return;
+  }
+  ScopedListPrefUpdate update(prefs, prefs::kGodsEyeBlockedDomains);
+  update->EraseValue(base::Value(args[1].GetString()));
+  ResolveJavascriptCallback(base::Value(callback_id), base::Value(true));
+}
+
+void GodsEyeHandler::HandleRemoveKeyword(const base::ListValue& args) {
+  AllowJavascript();
+  const std::string& callback_id = args[0].GetString();
+  PrefService* prefs = LocalState();
+  if (!prefs || args.size() < 2 || !args[1].is_string()) {
+    ResolveJavascriptCallback(base::Value(callback_id), base::Value(false));
+    return;
+  }
+  ScopedListPrefUpdate update(prefs, prefs::kGodsEyeBlockedKeywords);
+  update->EraseValue(base::Value(args[1].GetString()));
+  ResolveJavascriptCallback(base::Value(callback_id), base::Value(true));
+}
+
+void GodsEyeHandler::HandleAddAllowlistDomain(const base::ListValue& args) {
+  AllowJavascript();
+  const std::string& callback_id = args[0].GetString();
+  PrefService* prefs = LocalState();
+  if (!prefs || args.size() < 2 || !args[1].is_string()) {
+    ResolveJavascriptCallback(base::Value(callback_id), base::Value(false));
+    return;
+  }
+  const std::string domain = NormalizeDomainInput(args[1].GetString());
+  if (domain.empty() || domain.find('.') == std::string::npos) {
+    ResolveJavascriptCallback(base::Value(callback_id), base::Value(false));
+    return;
+  }
+  // Reject if already covered by the hardcoded allowlist.
+  if (DomainInHardcoded(domain)) {
+    ResolveJavascriptCallback(base::Value(callback_id), base::Value(false));
+    return;
+  }
+  // Reject if already in active user allowlist.
+  if (DomainInList(prefs->GetList(prefs::kGodsEyeUserAllowedDomains), domain)) {
+    ResolveJavascriptCallback(base::Value(callback_id), base::Value(false));
+    return;
+  }
+  // Reject if already pending review.
+  if (DomainInList(prefs->GetList(prefs::kGodsEyeAllowlistPending), domain)) {
+    ResolveJavascriptCallback(base::Value(callback_id), base::Value(false));
+    return;
+  }
+  ScopedListPrefUpdate update(prefs, prefs::kGodsEyeAllowlistPending);
+  base::Value::Dict entry;
+  entry.Set("domain", domain);
+  entry.Set("requested_at", base::Time::Now().InSecondsFSinceUnixEpoch());
+  update->Append(std::move(entry));
+  ResolveJavascriptCallback(base::Value(callback_id), base::Value(true));
+}
+
+void GodsEyeHandler::HandleRemoveAllowlistDomain(const base::ListValue& args) {
+  AllowJavascript();
+  const std::string& callback_id = args[0].GetString();
+  PrefService* prefs = LocalState();
+  if (!prefs || args.size() < 2 || !args[1].is_string()) {
+    ResolveJavascriptCallback(base::Value(callback_id), base::Value(false));
+    return;
+  }
+  const std::string domain = NormalizeDomainInput(args[1].GetString());
+  ScopedListPrefUpdate update(prefs, prefs::kGodsEyeUserAllowedDomains);
+  base::Value::List& list = update.Get();
+  list.EraseIf([&](const base::Value& entry) {
+    const base::Value::Dict* d = entry.GetIfDict();
+    if (!d) {
+      return false;
+    }
+    const std::string* val = d->FindString("domain");
+    return val && *val == domain;
+  });
+  ResolveJavascriptCallback(base::Value(callback_id), base::Value(true));
+}
+
+void GodsEyeHandler::HandleCancelAllowlistPending(
+    const base::ListValue& args) {
+  AllowJavascript();
+  const std::string& callback_id = args[0].GetString();
+  PrefService* prefs = LocalState();
+  if (!prefs || args.size() < 2 || !args[1].is_string()) {
+    ResolveJavascriptCallback(base::Value(callback_id), base::Value(false));
+    return;
+  }
+  const std::string domain = NormalizeDomainInput(args[1].GetString());
+  ScopedListPrefUpdate update(prefs, prefs::kGodsEyeAllowlistPending);
+  base::Value::List& list = update.Get();
+  list.EraseIf([&](const base::Value& entry) {
+    const base::Value::Dict* d = entry.GetIfDict();
+    if (!d) {
+      return false;
+    }
+    const std::string* val = d->FindString("domain");
+    return val && *val == domain;
+  });
+  ResolveJavascriptCallback(base::Value(callback_id), base::Value(true));
+}
