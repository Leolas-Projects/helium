@@ -0,0 +1,34 @@
+// Copyright 2025 The Helium Authors
+// You can use, redistribute, and/or modify this source code under
+// the terms of the GPL-3.0 license that can be found in the LICENSE file.
+
+#include "chrome/browser/ui/webui/gods_eye/restricted_page_ui.h"
+
+#include "chrome/browser/profiles/profile.h"
+#include "chrome/common/webui_url_constants.h"
+#include "content/public/browser/web_contents.h"
+#include "content/public/browser/web_ui.h"
+#include "content/public/browser/web_ui_controller.h"
+#include "content/public/browser/web_ui_data_source.h"
+#include "ui/webui/webui_util.h"
+
+HeliumRestrictedPage::HeliumRestrictedPage(content::WebUI* web_ui)
+    : WebUIController(web_ui) {
+  content::BrowserContext* browser_context =
+      web_ui->GetWebContents()->GetBrowserContext();
+  Profile* profile = Profile::FromBrowserContext(browser_context);
+  content::WebUIDataSource* source =
+      content::WebUIDataSource::CreateAndAdd(
+          profile, chrome::kHeliumRestrictedPageHost);
+
+  source->SetDefaultResource(IDR_HELIUM_RESTRICTED_PAGE_HTML);
+  source->DisableTrustedTypesCSP();
+  source->OverrideContentSecurityPolicy(
+      network::mojom::CSPDirectiveName::ScriptSrc,
+      "script-src 'self' 'unsafe-inline';");
+  source->OverrideContentSecurityPolicy(
+      network::mojom::CSPDirectiveName::ConnectSrc,
+      "connect-src 'self' https://timeapi.io;");
+}
+
+HeliumRestrictedPage::~HeliumRestrictedPage() = default;
--- a/chrome/browser/resources/restricted_page/index.html
+++ b/chrome/browser/resources/restricted_page/index.html
@@ -0,0 +1,124 @@
+<!DOCTYPE html>
+<html lang="en">
+<head>
+  <meta charset="UTF-8">
+  <meta name="viewport" content="width=device-width, initial-scale=1.0">
+  <title>Restricted</title>
+  <style>
+    :root {
+      --helium-blue: #3450d1;
+      --helium-blue-light: #e8ecfb;
+      --bg: #f5f5f5;
+      --surface: #ffffff;
+      --text: #1a1a1a;
+      --text-muted: #666;
+      --border: #e0e0e0;
+      --radius: 12px;
+    }
+    @media (prefers-color-scheme: dark) {
+      :root {
+        --bg: #1a1a1a; --surface: #242424; --text: #f0f0f0;
+        --text-muted: #aaa; --border: #333; --helium-blue-light: #1e2a5c;
+      }
+    }
+    * { box-sizing: border-box; margin: 0; padding: 0; }
+    body {
+      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
+      background: var(--bg); color: var(--text); min-height: 100vh;
+      display: flex; align-items: center; justify-content: center; padding: 24px;
+    }
+    .card {
+      background: var(--surface); border: 1px solid var(--border);
+      border-radius: var(--radius); padding: 40px 36px;
+      max-width: 520px; width: 100%; text-align: center;
+    }
+    .eye { font-size: 56px; margin-bottom: 16px; display: block; }
+    .title { font-size: 22px; font-weight: 700; color: var(--helium-blue); margin-bottom: 8px; }
+    .detail {
+      background: var(--helium-blue-light); border-radius: 8px;
+      padding: 12px 16px; margin: 18px 0; font-size: 14px; color: var(--helium-blue);
+    }
+    .detail-label { font-weight: 600; margin-bottom: 4px; }
+    .detail-value { font-family: monospace; font-size: 15px; word-break: break-all; }
+    hr { border: none; border-top: 1px solid var(--border); margin: 24px 0; }
+    .quote-label {
+      font-size: 11px; text-transform: uppercase;
+      letter-spacing: 0.08em; color: var(--text-muted); margin-bottom: 10px;
+    }
+    .quote { font-size: 16px; font-style: italic; line-height: 1.6; margin-bottom: 20px; }
+    .countdown { font-size: 13px; color: var(--text-muted); margin-top: 16px; }
+    .countdown strong { color: var(--helium-blue); font-size: 15px; }
+    .btn {
+      display: inline-block; margin-top: 20px; padding: 10px 22px;
+      background: var(--helium-blue); color: white; border-radius: 8px;
+      border: none; font-size: 14px; cursor: pointer; font-weight: 500;
+      text-decoration: none;
+    }
+  </style>
+</head>
+<body>
+<div class="card">
+  <span class="eye">&#128065;</span>
+  <div class="title">Access Restricted by God's Eye</div>
+  <div class="detail">
+    <div class="detail-label" id="blocked-label">Restricted</div>
+    <div class="detail-value" id="blocked-value">--</div>
+  </div>
+  <hr>
+  <div class="quote-label">Motivation</div>
+  <div class="quote" id="quote-text"></div>
+  <div class="countdown" id="countdown">Loading...</div>
+  <a href="chrome://godseye" class="btn">Open God's Eye Settings</a>
+</div>
+<script>
+(function() {
+  'use strict';
+  var QUOTES = [
+    "The secret of getting ahead is getting started.",
+    "It always seems impossible until it's done. -- Nelson Mandela",
+    "Focus on being productive instead of busy. -- Tim Ferriss",
+    "You don't have to be great to start, but you have to start to be great.",
+    "The successful warrior is the average man, with laser-like focus. -- Bruce Lee",
+    "One day or day one. You decide.",
+    "Your future is created by what you do today, not tomorrow.",
+    "Discipline is choosing between what you want now and what you want most.",
+    "Small daily improvements are the key to staggering long-term results.",
+    "Don't watch the clock; do what it does. Keep going. -- Sam Levenson"
+  ];
+  document.getElementById('quote-text').textContent =
+    QUOTES[Math.floor(Math.random() * QUOTES.length)];
+  var params = new URLSearchParams(window.location.search);
+  var reason = params.get('reason') || 'domain';
+  var value = params.get('value') || '';
+  var expiry = parseFloat(params.get('expiry') || '0');
+  document.getElementById('blocked-label').textContent =
+    reason === 'keyword' ? 'Restricted keyword detected:' : 'Restricted domain detected:';
+  document.getElementById('blocked-value').textContent = value || '(unknown)';
+  fetch('https://timeapi.io/api/time/current/zone?timeZone=UTC')
+    .then(function(r) { return r.json(); })
+    .then(function(d) {
+      var now = Math.floor(new Date(d.dateTime + 'Z').getTime() / 1000);
+      showCountdown(now);
+    })
+    .catch(function() { showCountdown(Math.floor(Date.now() / 1000)); });
+  function showCountdown(now) {
+    var el = document.getElementById('countdown');
+    if (!expiry || expiry <= 0) { el.textContent = 'Restrictions are active.'; return; }
+    var diff = expiry - now;
+    if (diff <= 0) {
+      el.innerHTML = 'Restrictions have <strong>expired</strong>. You may now update God\'s Eye.';
+      return;
+    }
+    var days = Math.floor(diff / 86400);
+    var hours = Math.floor((diff % 86400) / 3600);
+    var mins = Math.floor((diff % 3600) / 60);
+    var s = '';
+    if (days) s += days + ' day' + (days > 1 ? 's ' : ' ');
+    if (hours) s += hours + ' hr' + (hours > 1 ? 's ' : ' ');
+    if (mins || (!days && !hours)) s += mins + ' min';
+    el.innerHTML = 'Time remaining: <strong>' + s.trim() + '</strong>';
+  }
+})();
+</script>
+</body>
+</html>
