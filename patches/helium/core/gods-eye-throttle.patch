+// Copyright 2025 The Helium Authors
+// You can use, redistribute, and/or modify this source code under
+// the terms of the GPL-3.0 license that can be found in the LICENSE file.
+
+#ifndef CHROME_BROWSER_GODS_EYE_GODS_EYE_NAVIGATION_THROTTLE_H_
+#define CHROME_BROWSER_GODS_EYE_GODS_EYE_NAVIGATION_THROTTLE_H_
+
+#include <string>
+
+#include "base/memory/weak_ptr.h"
+#include "content/public/browser/navigation_throttle.h"
+
+class PrefService;
+
+namespace content {
+class NavigationThrottleRegistry;
+}  // namespace content
+
+class GURL;
+
+// Enforces Gods Eye blocking on navigations. Reads its configuration from the
+// global Local State so a single Gods Eye config applies uniformly across all
+// profiles, incognito windows, and guest sessions. Only the system profile
+// (profile picker) is exempted.
+class GodsEyeNavigationThrottle : public content::NavigationThrottle {
+ public:
+  static void MaybeCreateAndAdd(content::NavigationThrottleRegistry& registry);
+
+  explicit GodsEyeNavigationThrottle(
+      content::NavigationThrottleRegistry& registry);
+  ~GodsEyeNavigationThrottle() override;
+
+  GodsEyeNavigationThrottle(const GodsEyeNavigationThrottle&) = delete;
+  GodsEyeNavigationThrottle& operator=(const GodsEyeNavigationThrottle&) =
+      delete;
+
+  ThrottleCheckResult WillStartRequest() override;
+  ThrottleCheckResult WillRedirectRequest() override;
+  const char* GetNameForLogging() override;
+
+ private:
+  ThrottleCheckResult CheckNavigation();
+  bool IsGodsEyeActive() const;
+  bool IsAllowedHost(const GURL& url) const;
+  std::string MatchesDomain(const GURL& url) const;
+  std::string MatchesKeyword(const GURL& url) const;
+
+  // Cancels the current navigation and schedules a redirect to the Gods Eye
+  // restricted page via PostTask (safe to call from within throttle callbacks).
+  ThrottleCheckResult RedirectToRestrictedPage(const std::string& reason,
+                                               const std::string& value);
+
+  // Returns g_browser_process->local_state(), or nullptr during early startup.
+  static PrefService* GetLocalState();
+
+  base::WeakPtrFactory<GodsEyeNavigationThrottle> weak_factory_{this};
+};
+
+#endif  // CHROME_BROWSER_GODS_EYE_GODS_EYE_NAVIGATION_THROTTLE_H_
