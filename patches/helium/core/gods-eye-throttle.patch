+// Copyright 2025 The Helium Authors
+// You can use, redistribute, and/or modify this source code under
+// the terms of the GPL-3.0 license that can be found in the LICENSE file.
+
+#ifndef CHROME_BROWSER_GODS_EYE_GODS_EYE_ALLOWLIST_H_
+#define CHROME_BROWSER_GODS_EYE_GODS_EYE_ALLOWLIST_H_
+
+#include <string_view>
+
+#include "base/strings/string_util.h"
+#include "url/gurl.h"
+
+class PrefService;
+
+// Hard-coded allowlist of domains that always bypass Gods Eye blocking.
+// These cannot be modified by the user. Covers Google Workspace productivity
+// tools but deliberately excludes google.com (search).
+inline constexpr const char* kGodsEyeAllowedHosts[] = {
+    "accounts.google.com",    // Auth -- required for all Google sign-ins
+    "calendar.google.com",
+    "chat.google.com",
+    "classroom.google.com",
+    "contacts.google.com",
+    "docs.google.com",
+    "drive.google.com",
+    "forms.google.com",
+    "groups.google.com",
+    "jamboard.google.com",
+    "keep.google.com",
+    "mail.google.com",
+    "meet.google.com",
+    "sheets.google.com",
+    "sites.google.com",
+    "slides.google.com",
+    "voice.google.com",
+    "workspace.google.com",
+};
+
+// Returns true if |url| matches any entry in the hardcoded allowlist.
+// Comparison is case-insensitive; leading "www." is stripped before matching.
+// Whitelisted domains bypass ALL Gods Eye blocking (domain, keyword, and DOM).
+inline bool IsGodsEyeAllowedHost(const GURL& url) {
+  if (!url.has_host()) {
+    return false;
+  }
+  std::string host(url.host());
+  if (base::StartsWith(host, "www.", base::CompareCase::INSENSITIVE_ASCII)) {
+    host = host.substr(4);
+  }
+  for (const char* allowed : kGodsEyeAllowedHosts) {
+    if (base::EqualsCaseInsensitiveASCII(host, allowed)) {
+      return true;
+    }
+  }
+  return false;
+}
+
+// Returns true if |url|'s host matches any entry in the user-managed allowlist
+// stored in Local State (kGodsEyeUserAllowedDomains). Match is exact-host only
+// (no subdomain inheritance) after lowercasing and stripping leading "www.".
+bool IsGodsEyeUserAllowedDomain(PrefService* local_state, const GURL& url);
+
+// Convenience: returns true if |url| is allowed by either the hardcoded list
+// or the user-managed allowlist. Both lists bypass ALL Gods Eye blocking
+// (domain, keyword, and DOM keyword).
+inline bool IsGodsEyeAllowedAnywhere(PrefService* local_state,
+                                     const GURL& url) {
+  return IsGodsEyeAllowedHost(url) ||
+         IsGodsEyeUserAllowedDomain(local_state, url);
+}
+
+// Walks kGodsEyeAllowlistPending and promotes any entries whose 72-hour review
+// window has elapsed into kGodsEyeUserAllowedDomains. Safe to call from any
+// UI-thread context (PrefService is UI-thread-affine). Cheap if pending list
+// is empty.
+void GodsEyePromoteExpiredPendingAllowlist(PrefService* local_state);
+
+// 72 hours in seconds. Exposed for unit tests / WebUI countdown reuse.
+inline constexpr double kGodsEyeAllowlistReviewSeconds = 72.0 * 60.0 * 60.0;
+
+#endif  // CHROME_BROWSER_GODS_EYE_GODS_EYE_ALLOWLIST_H_
--- a/chrome/browser/gods_eye/gods_eye_allowlist.cc
+++ b/chrome/browser/gods_eye/gods_eye_allowlist.cc
@@ -0,0 +1,96 @@
+// Copyright 2025 The Helium Authors
+// You can use, redistribute, and/or modify this source code under
+// the terms of the GPL-3.0 license that can be found in the LICENSE file.
+
+#include "chrome/browser/gods_eye/gods_eye_allowlist.h"
+
+#include <optional>
+#include <string>
+
+#include "base/strings/string_util.h"
+#include "base/time/time.h"
+#include "base/values.h"
+#include "components/helium_services/gods_eye_pref_names.h"
+#include "components/prefs/pref_service.h"
+
+namespace {
+
+// Normalizes a candidate domain for comparison: lowercased, leading "www."
+// stripped. Returns an empty string for input that should not match anything.
+std::string Normalize(std::string_view raw) {
+  std::string out = base::ToLowerASCII(raw);
+  if (base::StartsWith(out, "www.", base::CompareCase::SENSITIVE)) {
+    out = out.substr(4);
+  }
+  return out;
+}
+
+}  // namespace
+
+bool IsGodsEyeUserAllowedDomain(PrefService* local_state, const GURL& url) {
+  if (!local_state || !url.has_host()) {
+    return false;
+  }
+  const std::string host = Normalize(url.host());
+  if (host.empty()) {
+    return false;
+  }
+  const base::ListValue& active =
+      local_state->GetList(prefs::kGodsEyeUserAllowedDomains);
+  for (const base::Value& entry : active) {
+    const base::DictValue* dict = entry.GetIfDict();
+    if (!dict) {
+      continue;
+    }
+    const std::string* candidate = dict->FindString("domain");
+    if (!candidate) {
+      continue;
+    }
+    if (Normalize(*candidate) == host) {
+      return true;
+    }
+  }
+  return false;
+}
+
+void GodsEyePromoteExpiredPendingAllowlist(PrefService* local_state) {
+  if (!local_state) {
+    return;
+  }
+  const base::ListValue& pending =
+      local_state->GetList(prefs::kGodsEyeAllowlistPending);
+  if (pending.empty()) {
+    return;
+  }
+  const double now = base::Time::Now().InSecondsFSinceUnixEpoch();
+  base::ListValue new_pending;
+  base::ListValue new_active =
+      local_state->GetList(prefs::kGodsEyeUserAllowedDomains).Clone();
+  bool changed = false;
+  for (const base::Value& entry : pending) {
+    const base::DictValue* dict = entry.GetIfDict();
+    if (!dict) {
+      continue;
+    }
+    const std::string* domain = dict->FindString("domain");
+    std::optional<double> requested = dict->FindDouble("requested_at");
+    if (!domain || !requested) {
+      continue;
+    }
+    if (now - *requested >= kGodsEyeAllowlistReviewSeconds) {
+      base::DictValue promoted;
+      promoted.Set("domain", *domain);
+      promoted.Set("added_at", now);
+      new_active.Append(std::move(promoted));
+      changed = true;
+    } else {
+      new_pending.Append(entry.Clone());
+    }
+  }
+  if (changed) {
+    local_state->SetList(prefs::kGodsEyeAllowlistPending,
+                         std::move(new_pending));
+    local_state->SetList(prefs::kGodsEyeUserAllowedDomains,
+                         std::move(new_active));
+  }
+}
